AUTH_SECRET=replace-with-at-least-32-random-characters

# Mail server resolution order:
# 1. IMAP_HOST_MAP / SMTP_HOST_MAP exact domain match
# 2. MAIL_HOST_MAP exact domain match
# 3. IMAP_HOST / SMTP_HOST
# 4. MAIL_HOST
# 5. mail.<login-email-domain>
#
# Examples:
# MAIL_HOST_MAP=bnix.io.vn=mail1.bnix.vn,example.com=mail2.bnix.vn
# MAIL_HOST=mail.shared-server.vn
MAIL_HOST=
MAIL_HOST_MAP=

IMAP_HOST=
IMAP_HOST_MAP=
IMAP_PORT=993
IMAP_SECURE=true

SMTP_HOST=
SMTP_HOST_MAP=
SMTP_PORT=465
SMTP_SECURE=true

# Optional. Empty allows all domains.
ALLOWED_EMAIL_DOMAINS=

NEXT_PUBLIC_WEBMAIL_NAME=BNIX WEBMAIL
NEXT_PUBLIC_MAX_ATTACHMENT_MB=10

# Production service port for Caddy reverse proxy.
# The systemd unit always binds HOSTNAME to 127.0.0.1.
PORT=3000
