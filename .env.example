# Session encryption key (required, auto-generated by installer)
AUTH_SECRET=

# IMAP
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true

# CalDAV / CardDAV (optional, for calendar & contacts)
DAV_HOST=
DAV_PORT=2080
DAV_SECURE=false

# Server bind
HOST=127.0.0.1
PORT=8000

# Data directory (for session storage)
DATA_DIR=

# Production service port. The systemd unit always binds HOSTNAME to 127.0.0.1.
PORT=3000

# Signature/settings storage. Production systemd sets this to /opt/bnix-webmail/data.
DATA_DIR=
