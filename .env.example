# Session encryption key (required, auto-generated by installer)
AUTH_SECRET=

# ── Mail Server (Optional Override) ──
# By default, the app auto-discovers mail servers via MX DNS records.
# Example: login with user@gmail.com → resolves gmail.com MX → imap.gmail.com
# Only set these if you need to force a specific server for ALL domains.
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true

# ── CalDAV / CardDAV (Optional) ──
# For calendar & contacts. Only needed if your mail server supports DAV.
DAV_HOST=
DAV_PORT=2080
DAV_SECURE=false

# ── Server ──
HOST=127.0.0.1
PORT=8000

# ── Data Directory ──
DATA_DIR=

# Production service port. The systemd unit always binds HOSTNAME to 127.0.0.1.
PORT=3000

# Signature/settings storage. Production systemd sets this to /opt/bnix-webmail/data.
DATA_DIR=
