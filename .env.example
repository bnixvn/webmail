AUTH_SECRET=replace-with-at-least-32-random-characters

# Optional. If empty, the app uses mail.<email-domain>.
MAIL_HOST=mail.demo.root.cloud

IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true

# Strongly recommended for public deployments.
ALLOWED_EMAIL_DOMAINS=demo.root.cloud

NEXT_PUBLIC_WEBMAIL_NAME=BNIX WEBMAIL
NEXT_PUBLIC_MAX_ATTACHMENT_MB=10

# Production service port for Caddy reverse proxy.
# The systemd unit always binds HOSTNAME to 127.0.0.1.
PORT=3000
